<section class="rz-collection" style="--rz-bg: {{ section.settings.background_color }}; --rz-card: {{ section.settings.card_color }}; --rz-text: {{ section.settings.text_color }}; --rz-accent: {{ section.settings.accent_color }};">
  <div class="rz-wrap">
    <header class="rz-head">
      <div>
        <p class="rz-kicker">{{ section.settings.kicker }}</p>
        <h1>{{ collection.title }}</h1>
        {% if collection.description != blank %}
          <div class="rz-desc">{{ collection.description }}</div>
        {% endif %}
      </div>
      <a class="rz-back" href="{{ routes.collections_url }}">Ver todas las categorias</a>
    </header>

    {% paginate collection.products by section.settings.products_per_page %}
      <div class="rz-grid">
        {% for product in collection.products %}
          <article class="rz-item">
            <a href="{{ product.url }}" class="rz-img-link">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title }}
              {% else %}
                <div class="rz-ph"></div>
              {% endif %}
            </a>
            <div class="rz-body">
              <p class="rz-type">{{ product.type }}</p>
              <h2><a href="{{ product.url }}">{{ product.title }}</a></h2>
              <p class="rz-price">{{ product.price | money }}</p>
              <a class="rz-btn" href="{{ product.url }}">Ver producto</a>
            </div>
          </article>
        {% else %}
          <p>No hay productos en esta coleccion aun.</p>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="rz-pagination" role="navigation" aria-label="Paginacion">
          {{ paginate | default_pagination }}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% stylesheet %}
  .rz-collection {
    background: var(--rz-bg);
    color: var(--rz-text);
    padding: 1.2rem 0 2rem;
    font-family: "Trebuchet MS", "Segoe UI", sans-serif;
  }

  .rz-wrap {
    max-width: 1220px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .rz-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .rz-kicker {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #5f6b7a;
  }

  .rz-head h1 {
    margin: 0.2rem 0 0;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
  }

  .rz-desc {
    margin-top: 0.55rem;
    color: #4f5d6f;
  }

  .rz-back {
    text-decoration: none;
    font-weight: 700;
    color: #102030;
    background: var(--rz-accent);
    border: 1px solid #c8ddee;
    border-radius: 999px;
    padding: 0.58rem 0.9rem;
    white-space: nowrap;
  }

  .rz-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .rz-item {
    background: var(--rz-card);
    border: 1px solid #d8e1ec;
    border-radius: 16px;
    overflow: hidden;
  }

  .rz-item img,
  .rz-ph {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }

  .rz-ph {
    background: linear-gradient(135deg, #dbe8f4, #f0f5fb);
  }

  .rz-body {
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .rz-type,
  .rz-price {
    margin: 0;
  }

  .rz-type {
    color: #617083;
    font-size: 0.8rem;
  }

  .rz-body h2 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.3;
  }

  .rz-body h2 a {
    color: var(--rz-text);
    text-decoration: none;
  }

  .rz-price {
    font-weight: 800;
  }

  .rz-btn {
    width: fit-content;
    text-decoration: none;
    border-radius: 999px;
    background: var(--rz-accent);
    border: 1px solid #b7d4ec;
    color: #102030;
    font-weight: 700;
    padding: 0.5rem 0.78rem;
    font-size: 0.85rem;
  }

  .rz-pagination {
    margin-top: 1.2rem;
  }

  @media (max-width: 1024px) {
    .rz-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .rz-head {
      flex-direction: column;
      align-items: start;
    }

    .rz-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Ranzen Collection",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Categoria"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 32,
      "step": 1,
      "default": 16
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1e2633"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#defeef"
    }
  ],
  "presets": [
    {
      "name": "Ranzen Collection"
    }
  ]
}
{% endschema %}
