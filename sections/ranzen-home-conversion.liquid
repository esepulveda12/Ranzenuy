      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Surface",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1d2430"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#defeef"
    },
